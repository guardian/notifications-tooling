{
	"name": "notifications-tooling",
	"module": "index.ts",
	"private": true,
	"type": "module",
	"prettier": "@guardian/prettier",
	"packageManager": "bun@1.3.14",
	"engines": {
		"bun": "1.3.14"
	},
	"workspaces": [
		"src/apps/*",
		"src/apps/workers/*",
		"src/packages/*"
	],
	"scripts": {
		"test": "bun test",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"docker:compose:up": "docker compose -f docker/docker-compose.local.yml up -d",
		"docker:compose:down": "docker compose -f docker/docker-compose.local.yml down"
	},
	"devDependencies": {
		"@guardian/eslint-config": "16.0.0",
		"@guardian/prettier": "11.0.0",
		"@guardian/tsconfig": "2.0.0",
		"@types/bun": "1.3.14",
		"@types/node": "26.1.1",
		"eslint": "9.39.5",
		"lefthook": "2.1.10",
		"prettier": "3.9.5",
		"tslib": "2.8.1",
		"typescript": "5.9.3"
	}
}
