{
  "name": "notifications-tooling",
  "module": "index.ts",
  "private": true,
  "type": "module",
  "workspaces": ["src/apps/*", "src/apps/workers/*", "src/packages/*"],
  "scripts": {
    "test": "bun test",
    "format": "bunx @biomejs/biome check --write ./src",
    "lint": "bunx @biomejs/biome lint ./src",
    "docker:compose:up": "docker compose -f docker/docker-compose.local.yml up -d",
    "docker:compose:down": "docker compose -f docker/docker-compose.local.yml down"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@types/bun": "latest"
  }
}
