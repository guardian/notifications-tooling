{
	"name": "notifications-tooling",
	"version": "0.0.0",
	"description": "Tooling for sending Guardian notifications",
	"private": true,
	"type": "module",
	"author": "The Guardian",
	"repository": {
		"type": "git",
		"url": "https://github.com/guardian/notifications-tooling.git"
	},
	"prettier": "@guardian/prettier",
	"packageManager": "bun@1.3.14",
	"engines": {
		"bun": "1.3.14"
	},
	"workspaces": [
		"src/apps/*",
		"src/apps/workers/*",
		"src/packages/*"
	],
	"scripts": {
		"prepare": "lefthook install",
		"dev": "sh -c 'trap \"kill 0\" EXIT INT TERM; bun run dev:backend & bun run dev:frontend'",
		"dev:backend": "cd src/apps/backend && bun run dev",
		"dev:frontend": "cd src/apps/frontend && BUN_PUBLIC_API_BASE_URL=${BUN_PUBLIC_API_BASE_URL:-http://localhost:3000} bun run dev",
		"test": "bun test",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"typecheck": "bun run --filter '*' typecheck",
		"docker:compose:up": "docker compose -f docker/docker-compose.local.yml up -d",
		"docker:compose:down": "docker compose -f docker/docker-compose.local.yml down"
	},
	"devDependencies": {
		"@guardian/eslint-config": "16.0.0",
		"@guardian/prettier": "11.0.0",
		"@guardian/tsconfig": "2.0.0",
		"@types/bun": "1.3.14",
		"@types/node": "26.1.1",
		"eslint": "9.39.5",
		"lefthook": "2.1.10",
		"prettier": "3.9.5",
		"tslib": "2.8.1",
		"typescript": "5.9.3"
	}
}
