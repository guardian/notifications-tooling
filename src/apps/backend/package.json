{
	"name": "backend",
	"module": "index.ts",
	"type": "module",
	"private": true,
	"scripts": {
		"start": "bun run --hot index.ts",
		"dev": "bun run --hot index.ts",
		"build": "bun build index.ts --outfile=dist/index.js --target=bun",
		"placeholder": "bun run --hot handler.ts",
		"build:placeholder": "bun build handler.ts --outfile=dist/handler.js --target=node --format=cjs",
		"test": "bun test",
		"typecheck": "tsc --noEmit"
	},
	"devDependencies": {
		"@codegenie/serverless-express": "5.0.0",
		"@types/aws-lambda": "8.10.162",
		"@types/bun": "1.3.14",
		"@types/express": "5.0.6",
		"@types/swagger-ui-express": "4.1.8"
	},
	"dependencies": {
		"@config": "workspace:*",
		"@http-logger": "workspace:*",
		"@utils": "workspace:*",
		"express": "5.2.1",
		"express-zod-safe": "3.2.1",
		"swagger-ui-express": "5.0.1",
		"zod": "4.4.3"
	}
}
