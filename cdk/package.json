{
	"name": "cdk",
	"version": "0.0.0",
	"private": true,
	"scripts": {
		"test": "bun test",
		"test-update": "bun test --update-snapshots",
		"format": "prettier --write \"{lib,bin}/**/*.ts\"",
		"lint": "eslint lib/** bin/** --no-error-on-unmatched-pattern",
		"synth": "cdk synth --path-metadata false --version-reporting false",
		"diff": "cdk diff --path-metadata false --version-reporting false"
	},
	"devDependencies": {
		"@types/bun": "1.3.14",
		"@guardian/cdk": "64.1.0",
		"@guardian/eslint-config": "14.0.1",
		"@guardian/prettier": "5.0.0",
		"@guardian/tsconfig": "2.0.0",
		"@types/mocha": "10.0.10",
		"@types/node": "26.1.0",
		"aws-cdk": "2.1131.0",
		"aws-cdk-lib": "2.261.0",
		"constructs": "10.7.0",
		"eslint": "9.39.2",
		"prettier": "3.8.3",
		"source-map-support": "0.5.21",
		"ts-node": "10.9.2",
		"typescript": "5.9.3"
	},
	"prettier": "@guardian/prettier",
	"allowScripts": {
		"fsevents@2.3.3": true,
		"unrs-resolver@1.12.2": true
	}
}
